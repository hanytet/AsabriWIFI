<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catat Pembayaran Tunai"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pilih Tagihan Pelanggan"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/spinnerTagihan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@android:drawable/btn_dropdown"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tanggal &amp; Waktu Bayar (Kosongkan jika hari ini)"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etTanggalBayar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Klik di sini untuk memilih tanggal &amp; jam"
        android:focusable="false"
        android:clickable="true"
        android:inputType="none"
        android:layout_marginBottom="10dp"/>
</LinearLayout>