<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Kiri: Info Pelanggan & Paket -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaPelangganLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pelanggan"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvPaketLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Paket Layanan"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <!-- Badge Metode Pembayaran -->
            <TextView
                android:id="@+id/tvMetodeLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIDTRANS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:background="#E3F2FD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Kanan: Waktu/Tanggal & Nominal Uang -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvWaktuLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:30 / 18 Jun"
                android:textColor="#888888"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvJumlahLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="14sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>