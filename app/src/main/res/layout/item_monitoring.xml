<?xml version="1.0" encoding="utf-8"?>
<!-- 👇 SUDAH FIXED: Menggunakan package AndroidX yang benar 👇 -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaPelanggan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pelanggan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tvNamaPaket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paket WiFi"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvJumlahTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <!-- Badge Jatuh Tempo -->
            <TextView
                android:id="@+id/tvJatuhTempo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 Jan 2026"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="#E0E0E0"
                android:textColor="#333333" />

            <!-- Keterangan Hari Keterlambatan -->
            <TextView
                android:id="@+id/tvKeterlambatan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Late: 5 Hari"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>