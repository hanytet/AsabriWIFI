<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Pembayaran"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola dan verifikasi pembayaran dari pelanggan"
            android:textSize="13sp"
            android:textColor="#64748B"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="20dp">

            <RadioGroup
                android:id="@+id/rgFilterPembayaran"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbSemuaPembayaran"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semua"
                    android:textSize="13sp"
                    android:checked="true"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/rbPembayaranPending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="13sp"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/rbPembayaranLunas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lunas"
                    android:textSize="13sp"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/rbPembayaranDitolaK"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ditolak"
                    android:textSize="13sp"
                    android:paddingHorizontal="12dp"/>
            </RadioGroup>
        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPembayaran"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="90dp" />

            <TextView
                android:id="@+id/tvDataKosong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tidak ada data pembayaran ditemukan."
                android:layout_gravity="center"
                android:visibility="gone"
                android:textColor="#64748B"
                android:textSize="14sp"/>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCatatTunai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Catat Tunai"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="#16A34A"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>