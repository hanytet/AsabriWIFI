<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvRiwayatNamaPaket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paket Premium"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0F172A" />

        <TextView
            android:id="@+id/tvRiwayatPeriode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Periode: 06 / 2026"
            android:textSize="13sp"
            android:textColor="#475569" />

        <TextView
            android:id="@+id/tvRiwayatMetode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Metode: MIDTRANS"
            android:textSize="13sp"
            android:textColor="#64748B" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvRiwayatJumlah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:text="Rp 150.000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2563EB" />

            <TextView
                android:id="@+id/tvRiwayatStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:text="Berhasil"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#16A34A"
                android:background="#DCFCE7"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>