<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvItemKategoriKeluhan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori Keluhan"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#0F172A" />

        <TextView
            android:id="@+id/tvItemIsiKeluhan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Isi deskripsi keluhan pelanggan..."
            android:textSize="14sp"
            android:textColor="#475569"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvItemTeknisiKeluhan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teknisi: -"
            android:textSize="13sp"
            android:textColor="#64748B"
            android:layout_marginTop="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#DCFCE7"> <TextView
                android:id="@+id/tvItemStatusKeluhan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#16A34A"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
            </androidx.cardview.widget.CardView>

        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>